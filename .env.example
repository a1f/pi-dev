# Copy to .env and fill in whatever you need. .env is gitignored.
#
# Pi has two auth paths and you only need ONE:
#
#   1. OAuth via `/login` inside pi (Claude Pro/Max, ChatGPT Plus/Pro,
#      GitHub Copilot subscriptions). Credentials land in ~/.pi/ and are
#      bind-mounted into the container by spawn.sh. No env vars needed.
#
#   2. Direct API keys via env vars below. Useful for headless runs,
#      CI, or providers without OAuth.
#
# If you're using OAuth (e.g. Codex / ChatGPT), you can leave every line
# below blank — pi falls back to whatever's in ~/.pi/.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Google (Gemini)
GEMINI_API_KEY=

# OpenRouter (multi-provider gateway)
OPENROUTER_API_KEY=

# GitHub fine-grained PAT, scoped to this repo only.
# Unused by the initial scaffold; reserved for future PR-flavored skills.
# Suggested scopes when you wire it up:
#   Contents: read/write, Pull requests: read/write,
#   Issues: read/write, Actions: read, Metadata: read
GITHUB_TOKEN=
