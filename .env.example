# Copy to .env and fill in whatever you need. .env is gitignored.
#
# Pi has two auth paths; you only need ONE:
#
#   1. OAuth via `/login` inside pi (Claude Pro/Max, ChatGPT Plus/Pro,
#      GitHub Copilot subscriptions). Credentials land in ~/.pi/agent/
#      on the dev VM. No env vars needed.
#
#   2. Direct API keys via env vars below. Useful for headless runs,
#      CI, or providers without OAuth.
#
# Lines starting with `export ` are tolerated (the parser strips the prefix).
# If you're using OAuth, you can leave every line below blank.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT / Codex)
OPENAI_API_KEY=

# Google (Gemini)
GEMINI_API_KEY=

# OpenRouter (multi-provider gateway)
OPENROUTER_API_KEY=

# GitHub fine-grained PAT, scoped to this repo only.
# Unused by initial scaffold; reserved for future PR-flavored skills.
# Suggested scopes when you wire it up:
#   Contents: read/write, Pull requests: read/write,
#   Issues: read/write, Actions: read, Metadata: read
GITHUB_TOKEN=

# Brave Search API — powers the web_search tool. https://brave.com/search/api/
BRAVE_API_KEY=

# Jina Reader — powers the web_read tool. https://jina.ai/reader/
# Optional: keyless r.jina.ai works; a key only raises rate limits.
JINA_API_KEY=
