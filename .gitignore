# secrets
.env
.env.local
*.pem
*.key
*.crt
.npmrc
.netrc
# pi-side credentials (defensive — pi keeps these under ~/.pi/, not the repo,
# but block them at the repo level just in case something writes here)
.pi/credentials*
.pi/auth*
.pi/oauth*
.pi/*.token

# node
node_modules/
npm-debug.log*
.npm/

# pi runtime state (per-worktree, lives inside the worktree, not in main)
.pi/sessions/
.pi/cache/
.pi/runs/

# editors / OS / agent harness state
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# build / logs
dist/
build/
*.log
